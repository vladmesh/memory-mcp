[Unit]
Description=Memory MCP daemon (shared semantic memory for control-panel agents)
After=network.target

[Service]
Type=simple
User=dev
Group=dev
WorkingDirectory=/home/dev/control-panel/services/memory-mcp
ExecStart=/home/dev/control-panel/services/memory-mcp/run.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
